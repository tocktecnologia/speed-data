{
  "name": "cloud-functions",
  "description": "Firebase Cloud Functions",
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/pubsub": "^5.2.3",
    "@langchain/anthropic": "^0.2.18",
    "@langchain/core": "^0.3.80",
    "@langchain/google-genai": "^0.0.26",
    "@langchain/langgraph": "^0.2.23",
    "@langchain/openai": "^0.3.14",
    "@mux/mux-node": "^7.3.3",
    "@onesignal/node-onesignal": "^2.0.1-beta2",
    "axios": "^1.13.5",
    "braintree": "^3.6.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.1.1",
    "qs": "^6.7.0",
    "razorpay": "^2.8.4",
    "stripe": "^8.0.1"
  },
  "devDependencies": {
    "eslint": "^6.8.0",
    "eslint-plugin-promise": "^4.2.1"
  },
  "scripts": {
    "lint": "eslint --max-warnings=0 .",
    "test": "node --test test/**/*.test.js",
    "serve": "firebase -P speed-data-tock emulators:start --only functions",
    "shell": "firebase -P speed-data-tock functions:shell",
    "start": "npm run shell",
    "logs": "firebase -P speed-data-tock functions:log",
    "compile": "cp ../../tsconfig.template.json ./tsconfig-compile.json && tsc --project tsconfig-compile.json"
  },
  "engines": {
    "node": "20"
  },
  "private": true,
