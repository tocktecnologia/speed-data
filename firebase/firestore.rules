rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user allows access to their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Races Collection
    match /races/{raceId} {
      allow read: if isAuthenticated();
      // Allow creation by anyone for now (or strictly admins if we could verify)
      // Since we don't have custom claims set up, we rely on client logic + basic auth for now
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Should technically be admin only

      // Participants Subcollection
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(participantId);
      }

      // Locations Subcollection (Live Telemetry)
      match /locations/{pilotId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(pilotId);
      }
      
      // Telemetry Logs Subcollection (Historical/Offline data)
      match /telemetry_logs/{logId} {
        allow read: if isAuthenticated(); // Or admin only
        allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      }
    }
  }
}
