rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user allows access to their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Admin screens need to search/list users by email to link competitors.
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Races Collection
    match /races/{raceId} {
      allow read: if isAuthenticated();
      // Allow creation by anyone for now (or strictly admins if we could verify)
      // Since we don't have custom claims set up, we rely on client logic + basic auth for now
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Should technically be admin only

      // Participants Subcollection
      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(participantId);

        // Legacy laps (no session) for backward compatibility
        match /laps/{lapId} {
          allow read: if isAuthenticated();
          allow write: if isOwner(participantId);
        }

        // Session-scoped data
        match /sessions/{sessionId} {
          allow read: if isAuthenticated();

          match /laps/{lapId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /crossings/{crossingId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /analysis/{docId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /state/{docId} {
            allow read, write: if isOwner(participantId);
          }
        }
      }

      // Locations Subcollection (Live Telemetry)
      match /locations/{pilotId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(pilotId);
      }
      
      // Telemetry Logs Subcollection (Historical/Offline data)
      match /telemetry_logs/{logId} {
        allow read: if isAuthenticated(); // Or admin only
        allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      }

      // Passings per race (checkpoints/lap closures)
      match /passings/{passingId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // Simulation config
    match /app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // tighten to admins if needed
    }

    match /simulation_testers/{emailId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // tighten to admins if needed
    }

    // Events Collection (admin/organizer access - currently any authenticated user)
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // tighten to admins when claims available

      match /teams/{teamId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated(); // tighten to admin/organizer when claims available

        match /members/{memberId} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated(); // tighten to admin/organizer when claims available
        }
      }

      match /competitors/{competitorId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // Session-owned telemetry data (Option 2)
      match /sessions/{sessionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();

        match /participants/{participantId} {
          allow read: if isAuthenticated();
          allow write: if isOwner(participantId);

          match /laps/{lapId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /crossings/{crossingId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /state/{docId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);
          }

          match /history_sessions/{historySessionId} {
            allow read: if isAuthenticated();
            allow write: if isOwner(participantId);

            match /laps/{lapId} {
              allow read: if isAuthenticated();
              allow write: if isOwner(participantId);
            }
          }
        }

        match /passings/{passingId} {
          allow read: if isAuthenticated();
          allow create, update: if isAuthenticated();
        }

        match /analysis/{docId} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated();
        }

        match /pilot_alerts/{pilotUid} {
          allow read: if isAuthenticated();
          // Write path is controlled by Cloud Functions.
          allow write: if false;
        }
      }
    }

    // -----------------------------
    // Portal Race public collections
    // -----------------------------

    // Public editorial content for Portal Race
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAuthenticated(); // tighten to editors/admins when claims are available
    }

    // Public championship catalog
    match /championships/{championshipId} {
      allow read: if true;
      allow write: if isAuthenticated(); // tighten to editors/admins when claims are available
    }

    // Public projection of events (safe for anonymous reads)
    match /events_public/{eventId} {
      allow read: if true;
      // Write should happen via Admin SDK / Cloud Functions.
      allow write: if false;
    }

    // Public results and standings
    match /results_public/{resultId} {
      allow read: if true;
      // Write should happen via Admin SDK / Cloud Functions.
      allow write: if false;
    }

    // Portal conversion leads
    match /portal_leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
  }
}
